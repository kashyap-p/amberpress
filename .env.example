# ── Database (PostgreSQL) ──────────────────────────────────────────────
# Required for both local dev and Vercel.
#
# On Vercel: create a Postgres database in the Vercel dashboard
# (Storage → Create → Postgres), then copy the two connection strings:
#   - DATABASE_URL  → the "pooled" connection (used at runtime by serverless)
#   - DIRECT_URL    → the "direct" connection (used by Prisma for migrations)
#
# Locally: use the same strings, or a local Postgres instance.
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require&pgbouncer=true&connection_limit=1
DIRECT_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ── Z.ai SDK (AI features) ─────────────────────────────────────────────
# Required for the AI co-writer (generate / rewrite / improve / summarize)
# and the live tech-news search.
#
# Get these from your Z.ai account dashboard.
ZAI_BASE_URL=https://internal-api.z.ai/v1
ZAI_API_KEY=your_zai_api_key_here

# Optional — only needed if your Z.ai plan requires them:
# ZAI_CHAT_ID=
# ZAI_USER_ID=
# ZAI_TOKEN=
